<?xml version="1.0" encoding="utf-8"?>
<CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    android:elevation="4dp"
    app:cardCornerRadius="8dp">
    
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">
        
        <!-- Course Image/Icon -->
        <ImageView
            android:id="@+id/courseIcon"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:src="@android:drawable/ic_dialog_info"
            android:scaleType="centerCrop"
            android:contentDescription="@string/app_name"
            android:layout_marginBottom="12dp"
            android:background="#E0E0E0" />
        
        <!-- Course Title -->
        <TextView
            android:id="@+id/courseTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Course Title"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@android:color/black"
            android:lines="2"
            android:ellipsize="end"
            android:layout_marginBottom="8dp" />
        
        <!-- Course Description -->
        <TextView
            android:id="@+id/courseDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Course description goes here"
            android:textSize="14sp"
            android:textColor="#666666"
            android:lines="2"
            android:ellipsize="end"
            android:layout_marginBottom="12dp" />
        
        <!-- Video Count -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            
            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@android:drawable/ic_media_play"
                android:tint="#007AFF"
                android:contentDescription="Videos" />
            
            <TextView
                android:id="@+id/videoCount"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="0 videos"
                android:textSize="12sp"
                android:textColor="#007AFF"
                android:layout_marginStart="8dp" />
            
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_view"
                android:tint="#999999"
                android:contentDescription="View" />
        </LinearLayout>
    </LinearLayout>
</CardView>
